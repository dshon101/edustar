<%- include('./partials/header') %>

  <section class="page-hero">
    <div class="hero-tag">📚 Free Textbooks</div>
    <h1>Free <em>Textbooks</em></h1>
    <p>Curriculum-aligned books for every subject and grade level across Africa.</p>
  </section>

  <div class="page-section">
    <div style="display:flex;gap:0.8rem;flex-wrap:wrap;margin-bottom:2rem;" id="filter-bar">
      <select id="filter-country" class="form-input" style="width:auto;" onchange="loadBooks()">
        <option value="">All Countries</option>
        <option value="ZW">🇿🇼 Zimbabwe</option>
        <option value="ZM">🇿🇲 Zambia</option>
        <option value="KE">🇰🇪 Kenya</option>
        <option value="NG">🇳🇬 Nigeria</option>
        <option value="ZA">🇿🇦 South Africa</option>
        <option value="GH">🇬🇭 Ghana</option>
      </select>
      <select id="filter-subject" class="form-input" style="width:auto;" onchange="loadBooks()">
        <option value="">All Subjects</option>
        <option>Mathematics</option><option>English</option><option>Science</option>
        <option>Biology</option><option>Chemistry</option><option>Physics</option>
        <option>History</option><option>Geography</option>
      </select>
    </div>

    <div id="books-grid" class="subjects-grid">
      <p style="color:var(--muted);">Loading books...</p>
    </div>
  </div>

  <script>
    async function loadBooks() {
      const country = document.getElementById('filter-country').value;
      const subject = document.getElementById('filter-subject').value;
      const grid    = document.getElementById('books-grid');
      grid.innerHTML = '<p style="color:var(--muted);">Loading...</p>';

      try {
        const qs   = new URLSearchParams({ country, subject }).toString();
        const res  = await fetch(`/api/books?${qs}`);
        const data = await res.json();
        if (!data.ok || !data.books.length) {
          grid.innerHTML = '<p style="color:var(--muted);">No books found. Try different filters.</p>';
          return;
        }
        grid.innerHTML = data.books.map(b => `
          <a href="${b.url || '#'}" target="_blank" rel="noopener" class="subject-card">
            <div class="subject-icon">${b.icon || '📚'}</div>
            <div class="subject-name">${b.title}</div>
            <div class="subject-desc">${b.description || ''}</div>
            <div class="subject-badge badge-orange" style="margin-top:0.5rem;">${b.country}</div>
          </a>`).join('');
      } catch(e) {
        grid.innerHTML = '<p style="color:var(--muted);">Could not load books. Please try again.</p>';
      }
    }

    window.addEventListener('load', () => {
      const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
      if (student?.country) document.getElementById('filter-country').value = student.country;
      loadBooks();
    });
  </script>

<%- include('./partials/footer') %>
