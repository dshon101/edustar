<%- include('./partials/header') %>

  <section class="page-hero">
    <div class="hero-tag">📚 Free Textbooks</div>
    <h1>Free <em>Textbooks</em></h1>
    <p>Curriculum-aligned books for every subject and grade level across Africa.</p>
  </section>

  <div class="page-section">
    <div class="filters-bar" id="filter-bar">
      <select id="filter-country" class="filter-select" onchange="loadBooks()">
        <option value="">🌍 All Countries</option>
        <option value="ZW">🇿🇼 Zimbabwe</option>
        <option value="ZM">🇿🇲 Zambia</option>
        <option value="KE">🇰🇪 Kenya</option>
        <option value="NG">🇳🇬 Nigeria</option>
        <option value="ZA">🇿🇦 South Africa</option>
        <option value="GH">🇬🇭 Ghana</option>
      </select>
      <select id="filter-subject" class="filter-select" onchange="loadBooks()">
        <option value="">📖 All Subjects</option>
        <option>Mathematics</option>
        <option>English</option>
        <option>Science</option>
        <option>Biology</option>
        <option>Chemistry</option>
        <option>Physics</option>
        <option>History</option>
        <option>Geography</option>
      </select>
    </div>

    <div id="books-count" style="color:var(--muted);font-size:0.85rem;margin-bottom:1rem;"></div>
    <div id="books-grid" class="books-grid">
      <p style="color:var(--muted);">Loading books...</p>
    </div>
  </div>

  <script>
    async function loadBooks() {
      const country = document.getElementById('filter-country').value;
      const subject = document.getElementById('filter-subject').value;
      const grid    = document.getElementById('books-grid');
      const count   = document.getElementById('books-count');
      grid.innerHTML = '<p style="color:var(--muted);">Loading...</p>';
      count.textContent = '';

      try {
        const qs   = new URLSearchParams({ country, subject }).toString();
        const res  = await fetch(`/api/books?${qs}`);
        const data = await res.json();

        if (!data.ok || !data.books.length) {
          grid.innerHTML = '<p style="color:var(--muted);">No books found. Try different filters.</p>';
          return;
        }

        count.textContent = `Showing ${data.books.length} book${data.books.length !== 1 ? 's' : ''}`;

        const countryNames = { ZW:'Zimbabwe', ZM:'Zambia', KE:'Kenya', NG:'Nigeria', ZA:'South Africa', GH:'Ghana', TZ:'Tanzania', UG:'Uganda', RW:'Rwanda', continental:'All Africa' };
        const badgeClass   = { Mathematics:'badge-core', English:'badge-core', Science:'badge-sciences', Biology:'badge-sciences', Chemistry:'badge-sciences', Physics:'badge-sciences', History:'badge-humanities', Geography:'badge-humanities' };

        grid.innerHTML = data.books.map(b => `
          <div class="book-card">
            <div class="book-icon">${b.icon || '📚'}</div>
            <div class="book-title">${b.title}</div>
            <div class="book-desc">${b.description || ''}</div>
            <div class="book-meta">
              <span class="book-tag">${countryNames[b.country] || b.country}</span>
              <span class="book-tag">${b.grade_range || ''}</span>
              <span class="book-tag ${badgeClass[b.subject] || 'badge-core'}">${b.subject}</span>
            </div>
            <a href="${b.url || '#'}" target="_blank" rel="noopener" class="btn btn-primary btn-sm" style="margin-top:1rem;width:100%;justify-content:center;">
              📖 Open / Download
            </a>
          </div>`).join('');
      } catch(e) {
        grid.innerHTML = '<p style="color:var(--muted);">Could not load books. Please try again.</p>';
      }
    }

    window.addEventListener('load', () => {
      const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
      if (student?.country) document.getElementById('filter-country').value = student.country;
      loadBooks();
    });
  </script>

<%- include('./partials/footer') %>