<%- include('./partials/header') %>

  <section class="page-hero">
    <div class="hero-tag" id="hero-tag">📊 Dashboard</div>
    <h1>Welcome back, <em id="student-name">Student</em></h1>
    <p>Keep up the great work! Here's your learning progress.</p>
  </section>

  <div class="page-section">
    <div class="progress-card">
      <div class="progress-stats">
        <div class="progress-stat"><div class="num" id="stat-points">0</div><div class="lbl">Points</div></div>
        <div class="progress-stat"><div class="num" id="stat-level">1</div><div class="lbl">Level</div></div>
        <div class="progress-stat"><div class="num" id="stat-quizzes">0</div><div class="lbl">Quizzes</div></div>
        <div class="progress-stat"><div class="num" id="stat-lessons">0</div><div class="lbl">Lessons done</div></div>
      </div>
      <div class="xp-bar-wrap"><div class="xp-bar" id="xp-bar"></div></div>
      <div class="xp-label"><span>Level <span id="xp-level">1</span></span><span id="xp-pts">0 / 500 XP</span></div>
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
      <a href="/subjects" class="btn btn-primary">📚 Continue Learning</a>
      <a href="/books"    class="btn btn-secondary">📖 Browse Books</a>
      <a href="/lesson"   class="btn btn-teal">🤖 Ask AI Tutor</a>
    </div>

    <div id="no-auth-msg" style="display:none;" class="card">
      <p>You need to <a href="/portal" style="color:var(--sun);">log in</a> to see your dashboard.</p>
    </div>
  </div>

  <script>
    window.addEventListener('load', () => {
      const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
      if (!student) {
        document.getElementById('no-auth-msg').style.display = 'block';
        return;
      }
      document.getElementById('student-name').textContent  = student.name?.split(' ')[0] || 'Student';
      document.getElementById('stat-points').textContent   = student.points  || 0;
      document.getElementById('stat-level').textContent    = student.level   || 1;
      document.getElementById('stat-quizzes').textContent  = student.quizzes_taken || 0;
      document.getElementById('stat-lessons').textContent  = (student.completed || []).length;
      const xpNeeded = (student.level || 1) * 500;
      const xpPct    = Math.min(((student.points || 0) % xpNeeded) / xpNeeded * 100, 100);
      document.getElementById('xp-bar').style.width    = xpPct + '%';
      document.getElementById('xp-level').textContent  = student.level || 1;
      document.getElementById('xp-pts').textContent    = `${student.points || 0} / ${xpNeeded} XP`;
      document.getElementById('hero-tag').textContent  =
        `${student.country || '🌍'} · Grade ${student.grade || '—'}`;
    });
  </script>

<%- include('./partials/footer') %>
