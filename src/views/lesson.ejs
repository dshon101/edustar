            meta: ['⏱ 25 min', '⭐ +50 pts', '🌍 Geography'],
            content: `
              <h3 style="color:var(--sun);margin-top:0;">Weather vs Climate</h3>
              <div style="display:grid;gap:0.8rem;margin:1rem 0;">
                <div style="background:rgba(255,107,43,0.08);border:1px solid rgba(255,107,43,0.2);padding:1rem;border-radius:8px;">
                  <strong style="color:var(--sun);">Weather</strong> — the short-term atmospheric conditions in a place. Example: "It is raining in Lusaka today."
