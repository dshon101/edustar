<%- include('./partials/header') %>

  <div id="lesson-page" style="display:none;">

    <!-- Breadcrumb -->
    <div class="page-section" style="padding-bottom:0;padding-top:1.5rem;">
      <nav style="font-size:0.85rem;color:var(--muted);margin-bottom:1.5rem;">
        <a href="/dashboard" style="color:var(--sun);text-decoration:none;">Dashboard</a>
        <span style="margin:0 0.5rem;">›</span>
        <a href="/subjects" style="color:var(--sun);text-decoration:none;">Subjects</a>
        <span style="margin:0 0.5rem;">›</span>
        <span id="bc-subject" style="color:var(--text);"></span>
      </nav>

      <!-- Subject Header -->
      <div class="lesson-subject-header" id="subject-header">
        <div style="display:flex;align-items:center;gap:1rem;">
          <div style="font-size:2.5rem;" id="subject-icon">📚</div>
          <div>
            <h2 id="subject-title" style="font-family:'Syne',sans-serif;font-size:1.4rem;margin:0;"></h2>
            <p id="subject-meta" style="color:var(--muted);font-size:0.85rem;margin:0.3rem 0 0;"></p>
          </div>
        </div>
        <span id="subject-badge" class="hero-tag" style="margin:0;"></span>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="lesson-layout page-section" style="padding-top:1.5rem;">

      <!-- Lesson Content -->
      <div class="lesson-main">
        <div class="card" id="lesson-card">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
            <h1 id="lesson-title" style="font-family:'Syne',sans-serif;font-size:1.4rem;margin:0;"></h1>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;" id="lesson-meta-tags"></div>
          </div>
          <div id="lesson-content" style="line-height:1.9;color:var(--text);"></div>
          <div style="display:flex;gap:0.8rem;flex-wrap:wrap;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);">
            <button class="btn btn-primary" id="complete-btn" onclick="markComplete()">
              ✅ Mark as Complete (+50 pts)
            </button>
            <button class="btn btn-secondary" onclick="goToAITutor()">🤖 Ask AI Tutor</button>
            <button class="btn btn-secondary" onclick="goToQuiz()">🧠 Quiz on This</button>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lesson-sidebar">
        <div class="card" style="padding:1.2rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
            <strong style="font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);">Lessons</strong>
            <span id="sidebar-progress" style="font-size:0.8rem;color:var(--gold);font-weight:700;"></span>
          </div>
          <div class="lesson-progress-bar-wrap" style="margin-bottom:1rem;">
            <div class="xp-bar" id="sidebar-xp-bar" style="width:0%;"></div>
          </div>
          <div id="lesson-list" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
          <div style="margin-top:1rem;display:flex;flex-direction:column;gap:0.5rem;">
            <button class="btn btn-primary btn-sm" id="next-btn" onclick="nextLesson()" style="display:none;">
              Next →
            </button>
            <a href="/quiz" class="btn btn-secondary btn-sm" style="text-align:center;">
              🧠 Take a Quiz
            </a>
            <a href="/subjects" class="btn btn-secondary btn-sm" style="text-align:center;">
              📚 All Subjects
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <!-- AI Chat fallback (no subject) -->
  <div id="ai-page" style="display:none;">
    <section class="page-hero" style="padding-bottom:1.5rem;">
      <div class="hero-tag">🤖 AI Tutor</div>
      <h1>Ask Your <em>AI Tutor</em></h1>
      <p>Ask any question about your studies and get a clear, helpful explanation.</p>
    </section>
    <div class="page-section" style="max-width:760px;">
      <div class="card" style="margin-bottom:1.5rem;">
        <div id="chat-messages" style="min-height:300px;max-height:500px;overflow-y:auto;display:flex;flex-direction:column;gap:1rem;margin-bottom:1.5rem;padding:0.5rem;">
          <div style="background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.2);border-radius:var(--radius-sm);padding:1rem;">
            <strong style="color:var(--teal);">EduStar AI</strong>
            <p style="margin-top:0.5rem;color:var(--text);line-height:1.7;">Hi! I'm your AI tutor. Ask me anything about your studies — maths, science, history, languages, or any subject. I'll explain it clearly at your level. What would you like to learn today?</p>
          </div>
        </div>
        <div style="display:flex;gap:0.8rem;">
          <input type="text" id="chat-input" class="form-input" placeholder="Ask a question about any subject..." style="flex:1;"
            onkeydown="if(event.key==='Enter')sendMessage()">
          <button class="btn btn-primary" onclick="sendMessage()" id="send-btn">Send</button>
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
        <span style="font-size:0.8rem;color:var(--muted);">Try asking:</span>
        <button class="btn btn-sm btn-secondary" onclick="prefill('Explain photosynthesis in simple terms')">Photosynthesis</button>
        <button class="btn btn-sm btn-secondary" onclick="prefill('How do I solve quadratic equations?')">Quadratic equations</button>
        <button class="btn btn-sm btn-secondary" onclick="prefill('What caused World War 1?')">World War 1</button>
        <button class="btn btn-sm btn-secondary" onclick="prefill('Explain supply and demand')">Supply and demand</button>
      </div>
    </div>
  </div>

  <script>
    // ── Lesson Data ──────────────────────────────────────────────
    const LESSONS = {
      math: {
        name: 'Mathematics', icon: '📐', badge: 'Core',
        lessons: [
          {
            id: 'math-1', title: 'Understanding Fractions',
            meta: ['⏱ 25 min', '⭐ +50 pts', '📐 Mathematics'],
            content: `
              <h3 style="color:var(--sun);margin-top:0;">What is a Fraction?</h3>
              <p>A fraction represents a <strong>part of a whole</strong>. It is written as one number over another: ½, ¾, ⅔.</p>
              <div style="background:rgba(255,107,43,0.08);border-left:3px solid var(--sun);padding:1rem;border-radius:0 8px 8px 0;margin:1rem 0;">
                <p>📌 The <strong>top number</strong> = numerator (how many parts you have)</p>
                <p>The <strong>bottom number</strong> = denominator (how many equal parts the whole is divided into)</p>
              </div>
              <h3 style="color:var(--sun);">Real-Life Example</h3>
              <div style="background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.2);padding:1rem;border-radius:8px;margin:1rem 0;">
                🥭 Cut a mango into 4 equal pieces. Eat 1 piece → you ate 1/4 of the mango.
              </div>
              <h3 style="color:var(--sun);">Adding Fractions (Same Denominator)</h3>
              <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);padding:1rem;border-radius:8px;font-family:monospace;font-size:1.1rem;">
                1/4 + 2/4 = 3/4
              </div>
              <h3 style="color:var(--sun);">Adding Fractions (Different Denominators)</h3>
              <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);padding:1rem;border-radius:8px;font-family:monospace;font-size:1.1rem;">
                1/2 + 1/3 → 3/6 + 2/6 = 5/6
              </div>
            `
          },
          {
            id: 'math-2', title: 'Introduction to Algebra',
            meta: ['⏱ 30 min', '⭐ +50 pts', '📐 Mathematics'],
            content: `
              <h3 style="color:var(--sun);margin-top:0;">What is Algebra?</h3>
              <p>Algebra uses <strong>letters</strong> to represent unknown numbers. The letter is called a <strong>variable</strong>.</p>
              <div style="background:rgba(255,107,43,0.08);border-left:3px solid var(--sun);padding:1rem;border-radius:0 8px 8px 0;margin:1rem 0;">
                <p>📌 Example: If x + 5 = 10, what is x?</p>
                <p>→ x = 10 - 5 = <strong>5</strong></p>
              </div>
              <h3 style="color:var(--sun);">Simple Equations</h3>
              <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);padding:1rem;border-radius:8px;font-family:monospace;">
                2x = 12 → x = 6<br>
                x - 3 = 7 → x = 10<br>
                3x + 2 = 14 → 3x = 12 → x = 4
              </div>
              <h3 style="color:var(--sun);">Real-Life Example</h3>
              <div style="background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.2);padding:1rem;border-radius:8px;margin:1rem 0;">
                🛒 You buy some oranges at $2 each and spend $10 total.<br>
                Let n = number of oranges.<br>
                2n = 10 → n = <strong>5 oranges</strong>
              </div>
            `
          },
          {
            id: 'math-3', title: 'Percentages & Ratios',
            meta: ['⏱ 25 min', '⭐ +50 pts', '📐 Mathematics'],
            content: `
              <h3 style="color:var(--sun);margin-top:0;">What is a Percentage?</h3>
              <p>A percentage means <strong>out of 100</strong>. The symbol is <strong>%</strong>.</p>
              <div style="background:rgba(255,107,43,0.08);border-left:3px solid var(--sun);padding:1rem;border-radius:0 8px 8px 0;margin:1rem 0;">
                <p>📌 50% = 50 out of 100 = one half</p>
                <p>📌 25% = 25 out of 100 = one quarter</p>
              </div>
              <h3 style="color:var(--sun);">Calculating Percentages</h3>
              <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);padding:1rem;border-radius:8px;font-family:monospace;">
                What is 20% of 80?<br>
                = (20 ÷ 100) × 80 = 0.2 × 80 = <strong>16</strong>
              </div>
              <h3 style="color:var(--sun);">What is a Ratio?</h3>
              <p>A ratio compares two quantities. Written as <strong>a:b</strong>.</p>
              <div style="background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.2);padding:1rem;border-radius:8px;margin:1rem 0;">
                🎒 A class has 20 boys and 15 girls.<br>
                Ratio of boys to girls = 20:15 = <strong>4:3</strong>
              </div>
            `
          }
        ]
      },
      english: {
        name: 'English Language', icon: '📖', badge: 'Core',
