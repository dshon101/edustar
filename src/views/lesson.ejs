    // ── Page Logic ───────────────────────────────────────────────
    let currentSubjectId = '';
    let currentLessonIdx = 0;
    let lessonData       = null;
    const chatMessages   = [];

    window.addEventListener('load', () => {
      const params    = new URLSearchParams(window.location.search);
      const subjectId = params.get('subject');
      const lessonId  = params.get('lesson');

      if (subjectId && LESSONS[subjectId]) {
        document.getElementById('lesson-page').style.display = 'block';
        loadSubject(subjectId, lessonId);
      } else if (subjectId) {
        // Subject exists in ALL_SUBJECTS but no lesson data — go to AI chat
        document.getElementById('ai-page').style.display = 'block';
        prefillSubject(subjectId);
      } else {
        document.getElementById('ai-page').style.display = 'block';
      }
    });

    function loadSubject(subjectId, lessonId) {
      currentSubjectId = subjectId;
      lessonData       = LESSONS[subjectId];

      // Subject header
      document.getElementById('bc-subject').textContent     = lessonData.name;
      document.getElementById('subject-icon').textContent   = lessonData.icon;
      document.getElementById('subject-title').textContent  = lessonData.name;
      document.getElementById('subject-badge').textContent  = lessonData.badge;

      const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
      const grade   = student?.grade || '';
      document.getElementById('subject-meta').textContent =
        `${grade}${grade ? ' · ' : ''}${lessonData.lessons.length} lessons`;

      // Find lesson index
      if (lessonId) {
        const idx = lessonData.lessons.findIndex(l => l.id === lessonId);
        currentLessonIdx = idx >= 0 ? idx : 0;
      } else {
        currentLessonIdx = 0;
      }

      renderSidebar();
      loadLesson(currentLessonIdx);
    }

    function renderSidebar() {
      const lessons   = lessonData.lessons;
      const completed = getCompleted();
      const doneCount = lessons.filter(l => completed.includes(l.id)).length;

      document.getElementById('sidebar-progress').textContent = `${doneCount} / ${lessons.length}`;
      document.getElementById('sidebar-xp-bar').style.width   = `${(doneCount / lessons.length) * 100}%`;

      document.getElementById('lesson-list').innerHTML = lessons.map((l, i) => {
        const isDone = completed.includes(l.id);
        const isActive = i === currentLessonIdx;
        return `<button onclick="loadLesson(${i})" style="
          text-align:left;width:100%;padding:0.7rem 0.9rem;border-radius:var(--radius-sm);
          border:1px solid ${isActive ? 'rgba(255,107,43,0.5)' : isDone ? 'rgba(0,201,167,0.3)' : 'var(--border)'};
          background:${isActive ? 'rgba(255,107,43,0.1)' : isDone ? 'rgba(0,201,167,0.08)' : 'transparent'};
          color:var(--text);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:0.88rem;
          display:flex;align-items:center;gap:0.6rem;
        ">
          <span style="font-size:1rem;">${isDone ? '✅' : isActive ? '▶️' : '⬜'}</span>
          ${l.title}
        </button>`;
      }).join('');
    }

    function loadLesson(idx) {
      currentLessonIdx = idx;
      const lesson     = lessonData.lessons[idx];
      const completed  = getCompleted();
      const isDone     = completed.includes(lesson.id);

      document.getElementById('lesson-title').textContent    = lesson.title;
      document.getElementById('lesson-content').innerHTML    = lesson.content;
      document.getElementById('lesson-meta-tags').innerHTML  = lesson.meta.map(m =>
        `<span style="background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:50px;padding:0.2rem 0.7rem;font-size:0.78rem;color:var(--muted);">${m}</span>`
      ).join('');

      const completeBtn = document.getElementById('complete-btn');
      if (isDone) {
        completeBtn.textContent  = '✅ Completed';
        completeBtn.disabled     = true;
        completeBtn.style.opacity = '0.6';
      } else {
        completeBtn.textContent  = '✅ Mark as Complete (+50 pts)';
        completeBtn.disabled     = false;
        completeBtn.style.opacity = '1';
      }

      // Show next button if not last lesson
      const nextBtn = document.getElementById('next-btn');
      nextBtn.style.display = idx < lessonData.lessons.length - 1 ? 'block' : 'none';

      window.scrollTo({ top: 0, behavior: 'smooth' });
      renderSidebar();
    }

    function markComplete() {
      const lesson    = lessonData.lessons[currentLessonIdx];
      const completed = getCompleted();
      if (completed.includes(lesson.id)) return;

      completed.push(lesson.id);
      localStorage.setItem('edustar_completed', JSON.stringify(completed));

      // Award XP
      const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
      if (student) {
        student.points = (student.points || 0) + 50;
        student.level  = Math.floor(student.points / 500) + 1;
        localStorage.setItem('edustar_current', JSON.stringify(student));
      }

      const btn = document.getElementById('complete-btn');
      btn.textContent  = '✅ Completed';
      btn.disabled     = true;
      btn.style.opacity = '0.6';

      renderSidebar();

      // Auto advance
      if (currentLessonIdx < lessonData.lessons.length - 1) {
        setTimeout(() => loadLesson(currentLessonIdx + 1), 800);
      }
    }

    function nextLesson() {
      if (currentLessonIdx < lessonData.lessons.length - 1) {
        loadLesson(currentLessonIdx + 1);
      }
    }

    function getCompleted() {
      try { return JSON.parse(localStorage.getItem('edustar_completed') || '[]'); } catch { return []; }
    }

    function goToAITutor() {
      window.location.href = '/lesson';
    }

    function goToQuiz() {
      window.location.href = '/quiz?subject=' + currentSubjectId;
    }

    function prefillSubject(subjectId) {
      const subj = ALL_SUBJECTS?.find(s => s.id === subjectId);
      if (subj) {
        const input = document.getElementById('chat-input');
        if (input) input.placeholder = `Ask anything about ${subj.name}...`;
      }
    }

    // ── AI Chat ──────────────────────────────────────────────────
    function prefill(text) {
      document.getElementById('chat-input').value = text;
      document.getElementById('chat-input').focus();
    }

    function addMessage(role, text) {
      const box = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.style.cssText = role === 'user'
        ? 'background:rgba(255,107,43,0.08);border:1px solid rgba(255,107,43,0.2);border-radius:var(--radius-sm);padding:1rem;align-self:flex-end;max-width:85%;'
        : 'background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.2);border-radius:var(--radius-sm);padding:1rem;';
      div.innerHTML = `<strong style="color:${role==='user'?'var(--sun)':'var(--teal)'}">${role==='user'?'You':'EduStar AI'}</strong><p style="margin-top:0.5rem;color:var(--text);line-height:1.7;white-space:pre-wrap;">${text.replace(/</g,'&lt;')}</p>`;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }

    async function sendMessage() {
      const input = document.getElementById('chat-input');
      const text  = input.value.trim();
      if (!text) return;
      input.value = '';
      addMessage('user', text);
      chatMessages.push({ role:'user', content:text });
      const btn = document.getElementById('send-btn');
      btn.disabled = true; btn.textContent = '...';
      try {
        const student = JSON.parse(localStorage.getItem('edustar_current') || 'null');
        const res  = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: chatMessages,
            system: student
              ? `You are EduStar's AI tutor for a ${student.grade} student in ${student.country}. Adapt explanations to their level.`
              : undefined
          })
        });
        const data  = await res.json();
        const reply = data.content?.[0]?.text || 'Sorry, I\'m having trouble right now. Please try again!';
        addMessage('ai', reply);
        chatMessages.push({ role:'assistant', content:reply });
      } catch {
        addMessage('ai', 'Sorry, I\'m having trouble right now. Please try again!');
      } finally {
        btn.disabled = false; btn.textContent = 'Send';
      }
    }
  </script>

