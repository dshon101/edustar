          {
            id: 'eng-1', title: 'Parts of Speech',
            meta: ['⏱ 20 min', '⭐ +50 pts', '📖 English'],
            content: `
              <h3 style="color:var(--sun);margin-top:0;">The 8 Parts of Speech</h3>
