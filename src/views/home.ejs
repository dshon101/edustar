<%- include('./partials/header') %>

  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-tag">🌍 Free for every African student</div>
          <h1 id="hero-heading">Quality Education,<br><em>Powered by AI</em></h1>
          <p class="hero-desc">Access curriculum-aligned lessons, free textbooks, and a peer-learning community — all personalised to your country, grade, and pace.</p>
          <div class="hero-cta">
            <a href="/portal" class="btn btn-primary">✨ Get Started Free</a>
            <a href="/portal" class="btn btn-secondary">🔑 Log In</a>
          </div>
        </div>
        <div class="hero-panel" aria-label="Supported countries">
          <div class="panel-title">Supported Across Africa</div>
          <div class="flag-grid">
            <span class="flag-chip">🇰🇪 Kenya</span>
            <span class="flag-chip">🇳🇬 Nigeria</span>
            <span class="flag-chip">🇿🇦 South Africa</span>
            <span class="flag-chip">🇹🇿 Tanzania</span>
            <span class="flag-chip">🇺🇬 Uganda</span>
            <span class="flag-chip">🇬🇭 Ghana</span>
            <span class="flag-chip">🇿🇼 Zimbabwe</span>
            <span class="flag-chip">🇿🇲 Zambia</span>
            <span class="flag-chip">🇪🇹 Ethiopia</span>
            <span class="flag-chip">🇷🇼 Rwanda</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="section-header">
      <h2 class="section-title">Why <span>EduStar?</span></h2>
    </div>
    <div class="features-grid">
      <div class="card">
        <div style="font-size:2rem;margin-bottom:1rem;">🤖</div>
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:0.5rem;">AI Tutor</h3>
        <p style="color:var(--muted);font-size:0.9rem;line-height:1.6;">Ask any question about your coursework and get a clear, grade-appropriate explanation instantly.</p>
      </div>
      <div class="card">
        <div style="font-size:2rem;margin-bottom:1rem;">📚</div>
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:0.5rem;">Free Textbooks</h3>
        <p style="color:var(--muted);font-size:0.9rem;line-height:1.6;">Access hundreds of curriculum-aligned textbooks for free — no downloads required.</p>
      </div>
      <div class="card">
        <div style="font-size:2rem;margin-bottom:1rem;">🌍</div>
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:0.5rem;">Your Curriculum</h3>
        <p style="color:var(--muted);font-size:0.9rem;line-height:1.6;">Content aligned to ZIMSEC, ECZ, WAEC, KCSE, NECTA, UNEB, WASSCE, CAPS, and more.</p>
      </div>
      <div class="card">
        <div style="font-size:2rem;margin-bottom:1rem;">🏆</div>
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:0.5rem;">Track Progress</h3>
        <p style="color:var(--muted);font-size:0.9rem;line-height:1.6;">Earn points, level up, and see your improvement over time on your personal dashboard.</p>
      </div>
    </div>
  </section>

<%- include('./partials/footer') %>
