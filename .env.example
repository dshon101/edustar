# Copy this file to .env and fill in your values
PORT=3000
NODE_ENV=development

# PostgreSQL (Render gives you this when you create a DB)
DATABASE_URL=postgresql://user:password@host:5432/edustar

# JWT Secret (make this long and random)
JWT_SECRET=your_super_secret_jwt_key_change_this

# AI - Pollinations is free, no key needed
# To use OpenAI instead, add your key here:
# OPENAI_API_KEY=sk-...
